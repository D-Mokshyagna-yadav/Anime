datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String?
  createdAt    DateTime    @default(now())
  watchlists   Watchlist[]
  reviews      Review[]
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  status    String   // e.g., 'PLAN_TO_WATCH', 'WATCHING', 'COMPLETED'
  progress  Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
