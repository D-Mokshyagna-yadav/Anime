{
  "name": "backend",
  "version": "1.0.0",
  "description": "SensuiWatch Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "prisma:prepare": "node ./scripts/prepare-prisma-schema.cjs",
    "prisma:generate": "npm run prisma:prepare && npx prisma generate",
    "prisma:db:push": "npm run prisma:prepare && npx prisma db push",
    "prisma:migrate": "npm run prisma:prepare && npx prisma migrate dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@consumet/extensions": "^1.8.8",
    "@prisma/client": "5.22.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.6.0",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
